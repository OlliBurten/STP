DATABASE_URL="postgresql://user:password@localhost:5432/drivermatch"
JWT_SECRET="change-me-to-a-long-random-string"
ADMIN_EMAILS="oliverharburt@gmail.com"
FRONTEND_URL="http://localhost:5173"
# Produktion: flera domäner med komma, t.ex. "https://transportplattformen.se,https://xxx.vercel.app"
PORT=3001
NODE_ENV=development
# Production: DEPLOYMENT=production. Demo: DEPLOYMENT=demo. (Förhindrar att demo-seed körs mot prod.)
# DEPLOYMENT=production
# Optional: email (Resend)
# RESEND_API_KEY=re_xxx
# EMAIL_FROM=noreply@transportplattformen.se
# MATCH_ALERTS_ENABLED=true
# Valfritt: URL:er som /api/health/check får anropa (för statussidan). Standard: transportplattformen.se + transportplattform-demo.vercel.app
# STATUS_CHECK_URLS="https://transportplattformen.se,https://transportplattform-demo.vercel.app"

# OAuth (Google, Microsoft) – samma Client IDs som frontend (VITE_GOOGLE_CLIENT_ID, VITE_AZURE_CLIENT_ID)
# GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# AZURE_CLIENT_ID=xxx-xxx-xxx
# AZURE_TENANT_ID=common
