{
  "name": "drivermatch-server",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node emails/build.mjs && node --watch --import ./instrument.js server.js",
    "start": "node emails/build.mjs && npx prisma generate && node scripts/migrate-add-columns.js && (npx prisma db push --accept-data-loss 2>/dev/null || true) && node --import ./instrument.js server.js",
    "build:emails": "node emails/build.mjs",
    "test": "node emails/build.mjs && APP_LISTEN=false node --test test/api.test.js test/companyProfileChecklist.test.js test/companyEnrichment.test.js test/demoAccounts.test.js test/demoInvites.test.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "node prisma/seed.js",
    "db:seed:demo": "DEMO_SEED=true node prisma/seed-demo.js",
    "db:verify-user": "node scripts/verify-user-email.js",
    "db:remove-demo-from-prod": "node scripts/remove-demo-users-from-prod.js",
    "db:migrate-add-columns": "node scripts/migrate-add-columns.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.89.0",
    "@prisma/client": "^6.0.0",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.8",
    "@sentry/node": "^10.47.0",
    "@sentry/react": "^10.49.0",
    "@vercel/analytics": "^2.0.1",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "esbuild": "^0.28.0",
    "express": "^4.21.0",
    "express-rate-limit": "^8.2.1",
    "google-auth-library": "^10.6.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^4.0.1",
    "node-cron": "^4.2.1",
    "organisationsnummer": "^1.2.0",
    "prisma": "^6.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "supertest": "^7.2.2"
  },
  "engines": {
    "node": ">=18"
  },
  "overrides": {
    "jose": "4.15.9"
  }
}
