{
  "rewrites": [
    {
      "source": "/sitemap-dynamic.xml",
      "destination": "https://nodejs-production-f3b9.up.railway.app/api/sitemap-dynamic.xml"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron-reminders",
      "schedule": "0 8 * * *"
    }
  ]
}
