# Sätt till backend-URL när du kör med API (t.ex. http://localhost:3001)
# Lämna tomt för endast frontend med mock-data.
# VITE_API_URL=http://localhost:3001

# Valfritt: för statussidan (/admin/status) – vilka webbadresser som är live respektive demo
# VITE_LIVE_URL=https://transportplattformen.se
# VITE_DEMO_URL=https://transportplattform-demo.vercel.app

# OAuth (Google, Microsoft) – Client IDs från respektive konsol
# VITE_GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# VITE_AZURE_CLIENT_ID=xxx-xxx-xxx
# VITE_AZURE_TENANT_ID=common
